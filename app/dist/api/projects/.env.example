# Banco de dados
DB_HOST=localhost
DB_PORT=3306
DB_NAME=SEU_DB
DB_USER=SEU_USUARIO
DB_PASS=SEU_SENHA
DB_AUTO_CREATE=0

# Alternativos (Hostinger)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=SEU_DB
MYSQLUSER=SEU_USUARIO
MYSQLPASSWORD=SEU_SENHA

# URLs
API_ORIGIN=https://seu-dominio.com.br
FRONTEND_URL=https://seu-dominio.com.br

# SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@seu-dominio.com.br
SMTP_PASS=COLOQUE_AQUI
SMTP_FROM=noreply@seu-dominio.com.br
SMTP_FROM_NAME=SeuNome

# Turnstile (opcional)
TURNSTILE_SITE_KEY=COLOQUE_AQUI
TURNSTILE_SECRET_KEY=COLOQUE_AQUI

# Segurança e manutenção
OPCACHE_RESET_ALLOW=0
OPCACHE_RESET_TOKEN=COLOQUE_UM_TOKEN_FORTE

MIGRATION_ALLOW_DROP=0
MIGRATION_TOKEN=COLOQUE_UM_TOKEN_FORTE

# Teste de email
MAIL_TEST_ALLOW=0
MAIL_TEST_TOKEN=COLOQUE_UM_TOKEN_DE_TESTE
